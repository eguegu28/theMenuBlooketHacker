// 1. Kyber Crystal Palette (Blue, Green, Red, Purple, Yellow)
const colors = ['#00A4EF', '#7FBA00', '#F25022', '#bc00ff', '#FFB900']; 
let sparkles = [];

class LightsaberSparkle {
    constructor(x, y, isExplosion = false) {
        this.x = x; this.y = y;
        this.isExplosion = isExplosion;
        
        // Blade length and angle
        this.length = Math.random() * 20 + 15; 
        this.angle = Math.random() * Math.PI * 2;
        
        // High speed for "clash" effect
        this.speed = isExplosion ? Math.random() * 12 + 6 : Math.random() * 3 + 1;
        this.color = colors[Math.floor(Math.random() * colors.length)];
        this.opacity = 1;
        
        // Spiral spin for the click
        this.spin = (Math.random() - 0.5) * 0.4; 
    }

    update() {
        if (this.isExplosion) {
            this.angle += this.spin; // This creates the spiral path
        }
        
        this.x += Math.cos(this.angle) * this.speed;
        this.y += Math.sin(this.angle) * this.speed;
        
        // Fade out quickly to maintain performance
        this.opacity -= 0.025;
        this.length *= 0.95; // Shrink as it fades
    }

    draw(ctx) {
        if (this.opacity <= 0) return;
        
        const endX = this.x + Math.cos(this.angle) * this.length;
        const endY = this.y + Math.sin(this.angle) * this.length;

        ctx.save();
        ctx.globalAlpha = this.opacity;
        ctx.lineCap = "round";

        // Layer 1: The Plasma Aura (Outer Glow)
        // We use a thicker line with a shadow for the "glow" look
        ctx.shadowBlur = 15;
        ctx.shadowColor = this.color;
        ctx.strokeStyle = this.color;
        ctx.lineWidth = 5;
        this.strokeLine(ctx, endX, endY);

        // Layer 2: The Kyber Core (White Center)
        // Turn off shadow for a crisp, hot center
        ctx.shadowBlur = 0;
        ctx.strokeStyle = "#ffffff";
        ctx.lineWidth = 1.5;
        this.strokeLine(ctx, endX, endY);
        
        ctx.restore();
    }

    strokeLine(ctx, ex, ey) {
        ctx.beginPath();
        ctx.moveTo(this.x, this.y);
        ctx.lineTo(ex, ey);
        ctx.stroke();
    }
}

// Click for a "Clash" Explosion
window.addEventListener('mousedown', (e) => {
    for (let i = 0; i < 40; i++) {
        sparkles.push(new LightsaberSparkle(e.clientX, e.clientY, true));
    }
});

// Cursor Trail
window.addEventListener('mousemove', (e) => {
    // Check particle count to protect your FPS
    if (sparkles.length < 120) {
        sparkles.push(new LightsaberSparkle(e.clientX, e.clientY, false));
    }
});

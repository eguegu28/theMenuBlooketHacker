class NeonParticle {
    constructor(x, y) {
        this.x = x;
        this.y = y;
        this.length = Math.random() * 30 + 20; // Length of the neon tube
        this.angle = Math.random() * Math.PI * 2;
        this.speed = Math.random() * 3 + 1;
        this.color = colors[Math.floor(Math.random() * colors.length)];
        this.opacity = 1;
        this.thickness = Math.random() * 3 + 2; // Base thickness
    }

    draw(ctx) {
        const endX = this.x + Math.cos(this.angle) * this.length;
        const endY = this.y + Math.sin(this.angle) * this.length;

        ctx.save();
        ctx.globalAlpha = this.opacity;
        ctx.lineCap = "round";

        // 1. The "Outer Aura" (Big, soft glow)
        ctx.shadowBlur = 20;
        ctx.shadowColor = this.color;
        ctx.strokeStyle = this.color;
        ctx.lineWidth = this.thickness * 2;
        this.drawLine(ctx, endX, endY);

        // 2. The "Inner Tube" (Intense color saturation)
        ctx.shadowBlur = 5; 
        ctx.lineWidth = this.thickness;
        this.drawLine(ctx, endX, endY);

        // 3. The "Hot Core" (Brightest center)
        ctx.shadowBlur = 0;
        ctx.strokeStyle = "#fff";
        ctx.lineWidth = this.thickness * 0.4; // Thinner white center
        this.drawLine(ctx, endX, endY);

        ctx.restore();
    }

    // Helper to keep code clean
    drawLine(ctx, endX, endY) {
        ctx.beginPath();
        ctx.moveTo(this.x, this.y);
        ctx.lineTo(endX, endY);
        ctx.stroke();
    }

    update() {
        this.x += Math.cos(this.angle) * this.speed;
        this.y += Math.sin(this.angle) * this.speed;
        this.opacity -= 0.012; // Slow fade looks better for neon
    }
}

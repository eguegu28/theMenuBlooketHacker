// Blue-only color palette
const colors = ['#00d2ff', '#3a7bd5', '#0072ff', '#00c6ff', '#004e92'];

class HeartParticle {
    constructor(x, y) {
        this.x = x;
        this.y = y;
        this.size = Math.random() * 15 + 5; // Overall scale of the heart
        this.angle = Math.random() * Math.PI * 2;
        this.speed = Math.random() * 2 + 1;
        this.color = colors[Math.floor(Math.random() * colors.length)];
        this.opacity = 1;
        this.rotation = Math.random() * Math.PI * 2; // Random heart rotation
    }

    draw(ctx) {
        if (this.opacity <= 0) return;
        ctx.save();
        ctx.globalAlpha = this.opacity;
        ctx.translate(this.x, this.y);
        ctx.rotate(this.rotation);
        
        const s = this.size;
        
        // Glow effect
        ctx.shadowBlur = 15;
        ctx.shadowColor = this.color;
        
        // Draw Heart Path
        ctx.beginPath();
        ctx.moveTo(0, s * 0.3);
        // Left side
        ctx.bezierCurveTo(0, 0, -s, 0, -s, s * 0.3);
        ctx.bezierCurveTo(-s, s * 0.6, 0, s, 0, s * 1.2);
        // Right side
        ctx.bezierCurveTo(0, s, s, s * 0.6, s, s * 0.3);
        ctx.bezierCurveTo(s, 0, 0, 0, 0, s * 0.3);
        
        // Fill with blue and add white glow core
        ctx.fillStyle = this.color;
        ctx.fill();
        
        // Inner white core for "Lightsaber" look
        ctx.shadowBlur = 0;
        ctx.strokeStyle = "#fff";
        ctx.lineWidth = 1.5;
        ctx.stroke();
        
        ctx.restore();
    }

    update() {
        this.x += Math.cos(this.angle) * this.speed;
        this.y += Math.sin(this.angle) * this.speed;
        this.opacity -= 0.012; // Slightly slower fade
        this.rotation += 0.02; // Gentle spin
    }
}

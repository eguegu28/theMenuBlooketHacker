const canvas = document.createElement('canvas');
const ctx = canvas.getContext('2d');
Object.assign(canvas.style, {
    position: 'fixed', inset: 0, zIndex: 2147483647, pointerEvents: 'none'
});
document.body.appendChild(canvas);

// Microsoft Fluent Brand Palette
const colors = ['#F25022', '#7FBA00', '#00A4EF', '#FFB900', '#6264A7']; 
let beams = [];

function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
}
window.addEventListener('resize', resize);
resize();

class FluentBeam {
    constructor(x, y) {
        this.x = x; this.y = y;
        this.size = Math.random() * 30 + 20;
        this.angle = Math.random() * Math.PI * 2;
        this.speed = Math.random() * 2 + 1;
        this.color = colors[Math.floor(Math.random() * colors.length)];
        this.opacity = 1;
    }

    update() {
        this.x += Math.cos(this.angle) * this.speed;
        this.y += Math.sin(this.angle) * this.speed;
        this.opacity -= 0.015;
    }

    draw() {
        ctx.save();
        ctx.globalAlpha = this.opacity;
        ctx.shadowBlur = 15;
        ctx.shadowColor = this.color;
        
        // Beam Core
        ctx.strokeStyle = "#FFFFFF";
        ctx.lineWidth = 3;
        ctx.lineCap = "square"; // Fluent geometric style
        
        ctx.beginPath();
        ctx.moveTo(this.x, this.y);
        ctx.lineTo(
            this.x + Math.cos(this.angle) * this.size,
            this.y + Math.sin(this.angle) * this.size
        );
        ctx.stroke();
        ctx.restore();
    }
}

window.addEventListener('mousemove', (e) => {
    for (let i = 0; i < 2; i++) beams.push(new FluentBeam(e.clientX, e.clientY));
});

function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    beams = beams.filter(b => b.opacity > 0);
    beams.forEach(b => { b.update(); b.draw(); });
    requestAnimationFrame(animate);
}

// Initialize for Microsoft Teams Tab
if (typeof microsoftTeams !== 'undefined') {
    microsoftTeams.app.initialize().then(() => {
        animate();
    });
} else {
    animate(); // Fallback for standard browser testing
}


